# Root .gitignore for Skillsutra Monorepo

# Dependencies
node_modules/
dist/
build/
.next/
out/
.pnp
.pnp.*

# Python
server/venv/
server/__pycache__/
*.pyc
*.pyo
venv/

# Environment Secrets (CRITICAL)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env*

# Solana / Anchor
programs/target/
.anchor/

# OS
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# Database local binary data
database/local_data/

# Local build logs / temporary lists
web/ts_errors.txt
